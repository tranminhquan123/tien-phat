# ===== SERVER ENV =====
# Sao chép file này thành .env và điền thông tin thật

# Database PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/tien_phat_db"

# JWT
JWT_SECRET="thay-bang-chuoi-ngau-nhien-dai-it-nhat-32-ky-tu"

# Server
PORT=4000
NODE_ENV=development

# URL của frontend (dùng cho CORS)
CLIENT_URL=http://localhost:5173

# Email (Nodemailer - nếu dùng)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="Tiến Phát <noreply@tienphat.com.vn>"
EMAIL_TO=info@tienphat.com.vn
