# ===== SERVER ENV =====
# Sao chép file này thành .env và điền thông tin thật

# Database PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/tien_phat_db"

# JWT
JWT_SECRET="thay-bang-chuoi-ngau-nhien-dai-it-nhat-32-ky-tu"

# Server
PORT=4000
NODE_ENV=development

# URL của frontend (dùng cho CORS và link mở trang quản trị trong email)
CLIENT_URL=http://localhost:5173

# Email thông báo liên hệ mới
# Với Gmail: bật xác minh 2 bước và tạo App Password, không dùng mật khẩu Gmail thông thường.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-character-app-password
EMAIL_FROM="Tiến Phát <your-email@gmail.com>"
# EMAIL_TO là địa chỉ dự phòng. Có thể thay đổi email nhận trong Admin > Cài đặt.
EMAIL_TO=your-email@gmail.com
