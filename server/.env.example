# ===== SERVER ENV =====
# Sao chép file này thành .env và điền thông tin thật

# Database PostgreSQL
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/tien_phat_db"

# JWT
JWT_SECRET="replace-with-a-long-random-secret"

# Server
PORT=4000
NODE_ENV=development

# URL frontend dùng cho CORS và link mở trang quản trị trong email
CLIENT_URL=http://localhost:5173

# ===== EMAIL THÔNG BÁO =====
# Khuyến nghị trên Render Free: dùng dịch vụ email API qua HTTPS.
RESEND_API_KEY=replace-with-your-resend-api-key
# Khi thử nghiệm có thể dùng địa chỉ mặc định của Resend và gửi tới email tài khoản Resend.
# Khi dùng thực tế với nhiều người nhận, hãy xác minh domain gửi.
RESEND_FROM="Tiến Phát Website <onboarding@resend.dev>"

# Email nhận thông báo dự phòng. Có thể thay đổi trong Admin > Cài đặt.
EMAIL_TO=your-email@example.com

# SMTP chỉ dùng ở môi trường cho phép kết nối các cổng SMTP.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=replace-with-app-password
EMAIL_FROM="Tiến Phát Website <your-email@example.com>"
